    <string name="accessibility_service_description">שירות זה מונע הודעות \"האם אתם עדיין צופים?\" בכל אפליקציות הסטרימינג.\nתומך ב: Yes, Netflix, YouTube, Disney+, Amazon Prime, HBO, Hulu, Cellcom TV, Partner TV, HOT ועוד.\nמזהה הודעות בעברית ובאנגלית, סוגר אותן אוטומטית, ומדמה פעילות שלט חכמה לפי האפליקציה.</string>
    <string name="app_name">Stream Keep Alive</string>
    <string name="app_subtitle">צפייה ללא הפרעות בכל אפליקציית סטרימינג</string>
    <string name="button_disable">הגדרות נגישות</string>
    <string name="button_enable">הגדרות נגישות</string>
    <string name="button_hotspot">נקודת גישה (Hotspot)</string>
    <string name="debug_title">Debug Telemetry</string>
    <string name="debug_waiting">מחכה לנתוני שירות...</string>
    <string name="description_active">השירות פעיל ומגן עליך מהודעות המתנה.\nתומך ב: Yes, Netflix, YouTube, Disney+, Prime ועוד.\nמזהה וסוגר הודעות אוטומטית + מדמה פעילות חכמה לפי האפליקציה.</string>
    <string name="description_inactive">השירות לא פעיל.\nלחץ על הכפתור למטה כדי לעבור להגדרות הנגישות\nוהפעל את \"Stream Keep Alive\".</string>
    <string name="status_active">✅ פעיל</string>
    <string name="status_inactive">⏸ לא פעיל</string>
    <string name="status_indicator_desc">מצב השירות</string>
