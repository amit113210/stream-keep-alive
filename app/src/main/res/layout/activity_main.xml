<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="32dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/text_high"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/appSubtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/app_subtitle"
                    android:textColor="@color/brand_primary_focused"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/version_placeholder"
                    android:textColor="@color/text_low"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Main Cards Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Internet Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/internetCardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/internet_card_title"
                        android:textColor="@color/text_high"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/internetStatusValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="-"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <!-- Hotspot Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/hotspotCardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hotspot_card_title"
                        android:textColor="@color/text_high"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hotspotStatusValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="-"
                        android:textColor="@color/text_mid"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/toggleHotspotButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="38dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/btn_primary"
                            android:text="@string/button_hotspot_settings"
                            android:focusable="true"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/showQrCodeButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="38dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/btn_secondary"
                            android:text="@string/button_show_qr_code"
                            android:focusable="true"
                            android:textAllCaps="false"
                            android:textColor="@color/text_high"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Speed Test Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/speedCardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/speed_card_title"
                        android:textColor="@color/text_high"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Metrics Container -->
                    <LinearLayout
                        android:id="@+id/speedMetricsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Ping:"
                                android:textColor="@color/text_mid"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/pingResultText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="-- ms"
                                android:textColor="@color/text_high"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Down:"
                                android:textColor="@color/text_mid"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/downloadResultText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="-- Mbps"
                                android:textColor="@color/text_high"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Up:"
                                android:textColor="@color/text_mid"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/uploadResultText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="-- Mbps"
                                android:textColor="@color/text_high"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/speedTestProgressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_bar_horizontal" />

                        <TextView
                            android:id="@+id/speedTestStatusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Ready"
                            android:textColor="@color/text_mid"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Legacy History text -->
                    <TextView
                        android:id="@+id/speedStatusValue"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="12dp"
                        android:text="-"
                        android:textColor="@color/text_mid"
                        android:textSize="12sp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/runSpeedTestButton"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/btn_primary"
                        android:focusable="true"
                        android:text="@string/button_run_speed_test"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom Actions Menu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/networkSettingsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_secondary"
                    android:focusable="true"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/button_network_settings"
                    android:textAllCaps="false"
                    android:textColor="@color/text_high"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/refreshInfoButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_secondary"
                    android:focusable="true"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/button_refresh_info"
                    android:textAllCaps="false"
                    android:textColor="@color/text_high"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/moreActionsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/btn_secondary"
                    android:focusable="true"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/button_more_actions"
                    android:textAllCaps="false"
                    android:textColor="@color/text_high"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Warnings / Debug -->
            <LinearLayout
                android:id="@+id/readinessWarningContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/readinessWarningText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/status_inactive"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/openBatterySettingsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/btn_secondary"
                        android:focusable="true"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="@string/button_fix_battery"
                        android:textAllCaps="false"
                        android:textColor="@color/text_high"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/openWriteSettingsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/btn_secondary"
                        android:focusable="true"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="@string/button_fix_write_settings"
                        android:textAllCaps="false"
                        android:textColor="@color/text_high"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/debugTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/debug_title"
                android:textColor="@color/text_low"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/debugTelemetryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:text="@string/debug_waiting"
                android:textColor="@color/text_low"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
